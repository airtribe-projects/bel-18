{
  "name": "course-rating-service",
  "version": "1.0.0",
  "description": "Course rating service for airtribe",
  "main": "app.js",
  "scripts": {
    "test": "jest",
    "dev": "nodemon app.js"
  },
  "author": "",
  "license": "ISC",
  "jest": {
    "collectCoverage": true, 
    "coverageReporters": [
      "text",
      "html",
      "lcov"
    ], 
    "coverageDirectory": "coverage", 
    "coverageThreshold": {
